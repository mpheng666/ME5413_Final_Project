Panels:
  - Class: rviz/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /Sensing1/PointCloud21
        - /PointCloud21/Status1
        - /Map4
      Splitter Ratio: 0.5117647051811218
    Tree Height: 380
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
      - /Current View1/Focal Point1
    Name: Views
    Splitter Ratio: 0.6096654534339905
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: PointCloud2
  - Class: rviz_panel::ME5413ControlPanel
    Name: ME5413ControlPanel
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
