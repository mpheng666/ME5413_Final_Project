<launch>
    <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">
        <remap from="cloud_in" to="/mid/points"/>
        <remap from="scan" to="/nav_scan"/>
        <rosparam>
            target_frame: base_link
            transform_tolerance: 0.01
            min_height: 0.1
            max_height: 1.5
            angle_min: -3.1415926 # -180 degrees
            angle_max: 3.1415926  # 180 degrees
            angle_increment: 0.0087 # M_PI/360.0 (approx 0.5 degrees
            scan_time: 0.1
            range_min: 0.2
            range_max: 50.0
            use_inf: true
            inf_epsilon: 1.0
        </rosparam>
    </node>
</launch>